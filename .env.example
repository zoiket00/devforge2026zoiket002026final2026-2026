# ┌─────────────────────────────────────────────────────────────┐
# │  DEVFORGE - VARIABLES DE ENTORNO                            │
# │  Copia este archivo como .env.local                         │
# │  NUNCA commitear .env.local al repositorio                  │
# └─────────────────────────────────────────────────────────────┘

# ── APLICACIÓN ────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── SEGURIDAD CRÍTICA ──────────────────────────────────────────
# Generar con: openssl rand -hex 32
CSRF_SECRET=CHANGE_ME_openssl_rand_hex_32_here_minimum_32_chars
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32_here_minimum_32_chars

# Generar con: openssl rand -hex 32 (32 bytes = 64 chars hex = AES-256)
ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32_here_exactly_64_hex_chars

# ── BASE DE DATOS ─────────────────────────────────────────────
# PostgreSQL (local o Neon.tech para serverless)
DATABASE_URL=postgresql://user:password@localhost:5432/devforge

# ── EMAIL ─────────────────────────────────────────────────────
# Opción A: Resend (recomendado 2026) - https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opción B: SMTP tradicional
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@tudominio.com
# SMTP_PASS=tu_password_smtp
# SMTP_FROM=noreply@tudominio.com

# Email donde recibirás los contactos
CONTACT_EMAIL=hola@devforge.dev

# ── WHATSAPP ──────────────────────────────────────────────────
WHATSAPP_NUMBER=573001234567

# ── WEBHOOKS DE SEGURIDAD ─────────────────────────────────────
# Slack webhook para alertas de seguridad críticas
# SECURITY_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── ANALYTICS ─────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── MONITORING ────────────────────────────────────────────────
# Sentry - https://sentry.io
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_ORG=tu-org
SENTRY_PROJECT=devforge
SENTRY_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ── AI APIs ───────────────────────────────────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (opcional)
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CLOUD AWS (opcional) ──────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_BUCKET_NAME=devforge-uploads

# ── CLOUDFLARE (opcional) ─────────────────────────────────────
# CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
# CLOUDFLARE_ZONE_ID=xxxxxxxxxxxxxxxxxxxx
# CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx

# ── VERCEL (solo en CI/CD) ────────────────────────────────────
# VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxx
# VERCEL_ORG_ID=xxxxxxxxxxxxxxxxxxxx
# VERCEL_PROJECT_ID=xxxxxxxxxxxxxxxxxxxx

# ── REDES SOCIALES (para preview cards) ───────────────────────
